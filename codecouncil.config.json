{
  "projectName": "CodeCouncil",
  "baseBranch": "main",
  "workspaceDir": ".codecouncil",
  "agents": {
    "codex": {
      "enabled": true,
      "command": "codex",
      "models": {},
      "planArgs": ["exec", "--json", "--sandbox", "read-only"],
      "implementArgs": ["exec", "--json", "--sandbox", "workspace-write"],
      "reviewArgs": ["exec", "--json", "--sandbox", "read-only"],
      "maxRuntimeSeconds": 900
    },
    "claude": {
      "enabled": true,
      "command": "claude",
      "models": {},
      "planArgs": ["-p", "--verbose", "--output-format", "stream-json", "--permission-mode", "plan"],
      "implementArgs": ["-p", "--verbose", "--output-format", "stream-json", "--permission-mode", "acceptEdits"],
      "reviewArgs": ["-p", "--verbose", "--output-format", "stream-json", "--permission-mode", "plan"],
      "maxRuntimeSeconds": 900
    }
  },
  "testCommands": ["pnpm test"],
  "testContainer": {
    "image": "node:20-bookworm-slim",
    "timeoutSeconds": 600
  },
  "ignore": [".env", ".env.*", "node_modules", ".git", ".codecouncil", "dist", "coverage"],
  "review": {
    "maxDiffBytes": 120000
  },
  "safety": {
    "requireApprovalBeforeApply": true,
    "blockSecretFiles": true,
    "createCommitOnImplementation": false,
    "defaultPlanModeReadOnly": true,
    "allowImplementationByDefault": false,
    "secretPatterns": []
  }
}
